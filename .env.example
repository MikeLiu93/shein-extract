# 复制为 .env（开发环境）或由首次运行向导写入 %APPDATA%\shein-extract\config.env（员工电脑）。
# .env 已 gitignore，不会被提交。

# ── Anthropic API key（必填，用于 AI 生成 eBay 标题）─────────────────────────
# 公司公用一个 key，建议在 Anthropic 后台设月度上限。
ANTHROPIC_API_KEY=sk-ant-...

# ── 路径配置（三条路径独立可设，无依赖）─────────────────────────────────────
# 输入 Excel 所在目录（共享云端硬盘上）
SHEIN_SUBMITTED_DIR=G:\共享云端硬盘\02 希音\Auto Pipeline\Listing - web links (submitted)

# 输入 Excel 文件名（可改，但表结构必须相同：A=Seq B=Website C=Date D=Status）
SHEIN_INPUT_FILENAME=Shein Submited Links.xlsx

# 输出根目录（共享云端硬盘上）
SHEIN_OUTPUT_DIR=G:\共享云端硬盘\02 希音\Auto Pipeline\Listing - completed 2nd

# 备份目录（建议放独立的"备份共享云盘"，不要和源 Excel 同一个盘）
SHEIN_BACKUP_DIR=G:\共享云端硬盘\Shein备份\总表
