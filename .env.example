# Copy to .env and fill in. .env is gitignored.

# Anthropic API key for AI title generation in shein_scraper.py
ANTHROPIC_API_KEY=sk-ant-...

# Gmail App Password (NOT your Gmail login). Generate at:
#   https://myaccount.google.com/apppasswords
# Used by notify.py to send captcha/login alerts.
GMAIL_APP_PASSWORD=

# Google Drive mount letter. Default: G: (Google Drive for Desktop default).
# Override if your Drive is mounted elsewhere (e.g. D:).
SHEIN_DRIVE=G:

# Optional full-path overrides (rare — only if your Drive folder names differ).
# SHEIN_AUTO_PIPELINE_BASE=G:\共享云端硬盘\02 希音\Auto Pipeline
# SHEIN_BACKUP_BASE=G:\我的云端硬盘\Backup\Shein\总表
