# 复制为 .env（开发环境）或由首次运行向导写入 %APPDATA%\shein-extract\config.env（员工电脑）。
# .env 已 gitignore，不会被提交。

# ── Anthropic API key（必填，用于 AI 生成 eBay 标题）─────────────────────────
# 公司公用一个 key，建议在 Anthropic 后台设月度上限。
ANTHROPIC_API_KEY=sk-ant-...

# ── 路径配置（三条路径独立可设，无依赖）─────────────────────────────────────
# 输入 Excel 所在目录（共享云端硬盘上）
SHEIN_SUBMITTED_DIR=G:\共享云端硬盘\02 希音\Auto Pipe